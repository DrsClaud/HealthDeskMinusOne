rules_version = '2';
service cloud.firestore {

  match /databases/{database}/documents {

    // ================================================================
    // ACTIVE COLLECTIONS
    // ================================================================

    match /locations/{location} {
      allow read: if true;
      allow create: if request.auth.uid in request.resource.data.users;
      allow delete: if false;

      // waitTimes: public. queue/queueNumber: only via Cloud Function joinVirtualQueue (admin SDK)
      allow update: if
        (isLoggedIn() && isValidUser()) ||
        isAdmin() ||
        (isLoggedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['users'])) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['waitTimes']) ||
        (isLoggedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['queue', 'queueNumber']));
    }

    match /kijabe_rate_limits/{userId} {
      allow read: if isLoggedIn() && request.auth.uid == userId;
      allow create, update: if isLoggedIn() && request.auth.uid == userId && isValidRateLimitDoc();
      allow delete: if false;

      function isValidRateLimitDoc() {
        let d = request.resource.data;
        return d.keys().hasAll(['userId', 'lastReset', 'modules']) &&
               d.userId is string &&
               d.lastReset is number &&
               d.modules is map;
      }
    }

    match /chat/{uid} {
      allow read, write: if isLoggedIn() && request.auth.uid == uid;

      match /threads/{id} {
        allow read, write: if isLoggedIn() && request.auth.uid == uid;
      }
    }

    match /users/{uid} {
      allow get:  if isLoggedIn() && (request.auth.uid == uid || isAdmin());
      // List/queries are restricted to platform admins only.
      // Team member lookups for org admins happen via Cloud Functions and return sanitized data.
      allow list: if request.auth != null && request.auth.token.admin == true;
      allow create: if isLoggedIn() &&
        request.auth.uid == uid &&
        request.resource.data.keys().hasAll(['uid', 'email', 'name', 'lastName', 'role']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.role in ['patient', 'facility', 'professional', 'admin'];
      // Block self-escalation of privileged fields
      allow update: if isLoggedIn() &&
        request.auth.uid == uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['admin', 'role']);
      allow delete: if false;

      match /checkout_sessions/{id} {
        allow read, write: if isLoggedIn() && request.auth.uid == uid;
      }
      match /payments/{id} {
        allow read: if isLoggedIn() && request.auth.uid == uid;
        allow write: if false; // Stripe extension writes via admin SDK
      }
      match /subscriptions/{id} {
        allow read: if isLoggedIn() && request.auth.uid == uid;
      }
      match /medications/{medicationId} {
        allow read, delete: if request.auth.uid == uid;
        allow create, update: if request.auth.uid == uid && isValidMedication();

        function isValidMedication() {
          let d = request.resource.data;
          return d.keys().hasAll(['name', 'dosage', 'frequency']) &&
                 d.name is string && d.name.size() > 0 &&
                 d.dosage is string &&
                 d.frequency is string;
        }
      }
      match /medicationTracking/{dateId} {
        allow read, delete: if request.auth.uid == uid;
        allow create, update: if (request.auth.uid == uid || request.auth.token.admin == true) &&
          isValidMedicationTracking();

        function isValidMedicationTracking() {
          let d = request.resource.data;
          return d.keys().hasAll(['date', 'medications']) &&
                 d.date is string && d.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
                 d.medications is map &&
                 (!d.keys().hasAny(['createdAt']) || d.createdAt is timestamp) &&
                 (!d.keys().hasAny(['updatedAt']) || d.updatedAt is timestamp);
        }
      }
      match /medicationReminders/{medicationId} {
        allow read, delete: if request.auth.uid == uid;
        allow create, update: if request.auth.uid == uid && isValidMedicationReminder();

        function isValidMedicationReminder() {
          let d = request.resource.data;
          return d.keys().hasAll(['medicationId', 'medicationName', 'times', 'timezone', 'enabled']) &&
                 d.medicationId is string && d.medicationId.size() > 0 &&
                 d.medicationName is string && d.medicationName.size() > 0 &&
                 d.times is list && d.times.size() > 0 && d.times.size() <= 24 &&
                 d.timezone is string && d.timezone.size() > 0 &&
                 d.enabled is bool;
        }
      }
      match /facilityAlerts/{facilityId} {
        allow read, delete: if request.auth.uid == uid;
        allow create, update: if request.auth.uid == uid && isValidFacilityAlert();

        function isValidFacilityAlert() {
          let d = request.resource.data;
          return d.keys().hasAll(['facilityId', 'facilityName', 'enabled', 'alertTimes', 'timezone']) &&
                 d.facilityId is string && d.facilityId.size() > 0 &&
                 d.facilityName is string && d.facilityName.size() > 0 &&
                 d.enabled is bool &&
                 d.alertTimes is list && d.alertTimes.size() <= 24 &&
                 d.timezone is string && d.timezone.size() > 0;
        }
      }
      match /profile/{docId} {
        allow read, write: if request.auth.uid == uid;
      }
      match /chartmind_savedtranscripts/{transcriptId} {
        allow read: if request.auth.uid == uid && request.auth.token.admin == true;
        allow create, update: if request.auth.uid == uid &&
          request.auth.token.admin == true &&
          request.resource.data.userId == uid &&
          isValidSavedTranscript();
        allow delete: if request.auth.uid == uid && request.auth.token.admin == true;

        function isValidSavedTranscript() {
          let d = request.resource.data;
          return d.keys().hasAll(['userId', 'title', 'body', 'type']) &&
                 d.userId == uid &&
                 d.title is string && d.title.size() > 0 &&
                 d.body is string && d.body.size() > 0 &&
                 d.type == 'example_transcript' &&
                 (!d.keys().hasAny(['createdAt']) || d.createdAt is timestamp) &&
                 (!d.keys().hasAny(['updatedAt']) || d.updatedAt is timestamp);
        }
      }
      match /facilityAlertTracking/{dateId} {
        allow read, delete: if request.auth.uid == uid;
        allow create, update: if (request.auth.uid == uid || request.auth.token.admin == true) &&
          isValidFacilityAlertTracking();

        function isValidFacilityAlertTracking() {
          let d = request.resource.data;
          return d.keys().hasAll(['date', 'sentAlerts']) &&
                 d.date is string && d.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
                 d.sentAlerts is list &&
                 (!d.keys().hasAny(['createdAt']) || d.createdAt is timestamp) &&
                 (!d.keys().hasAny(['updatedAt']) || d.updatedAt is timestamp);
        }
      }
      match /auctionSubscriptions/{subscriptionId} {
        allow read: if request.auth.uid == uid;
        allow write: if request.auth.token.admin == true;
      }
      match /listings/{zipCode} {
        allow read: if request.auth.uid == uid;
        allow write: if isLoggedIn() && (
          (request.auth.uid == uid && (
            (request.resource != null &&
             request.resource.data.status in ['pending'] &&
             request.resource.data.type in ['promotion', 'featured']) ||
            request.resource == null
          )) ||
          request.auth.token.admin == true
        );
      }
      match /invoices/{invoiceId} {
        allow read: if request.auth.uid == uid;
        allow write: if request.auth.token.admin == true;
      }
    }

    match /zips/{zip} {
      allow read, create: if true;
      allow delete: if false;

      match /listings/{userId} {
        allow read: if true;
        allow create, update: if isLoggedIn() && (
          (request.auth.uid == userId &&
           request.resource.data.userId == request.auth.uid &&
           request.resource.data.type in ['promotion', 'featured']) ||
          request.auth.token.admin == true
        );
        allow delete: if isLoggedIn() && (request.auth.uid == userId || request.auth.token.admin == true);
      }

      match /listingsArchive/{archiveId} {
        allow read: if true;
        allow write: if request.auth.token.admin == true;
      }
    }

    match /plans/{id} {
      allow read: if true;

      match /prices/{id} {
        allow read: if true;
      }
      match /tax_rates/{id} {
        allow read: if true;
      }
    }

    match /emails/{email} {
      // Only admins write client-side; cloud functions use admin SDK and bypass rules
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }

    match /messages/{message} {
      // Only facility staff create from client; queue signup SMS is created by Cloud Function joinVirtualQueue
      allow create: if isFacilityStaff();
      allow read, update, delete: if false;
    }

    match /registrations/{registrationId} {
      // Unauthenticated patients may read only pre-submission docs via SMS link.
      // Once submitted (contains PHI), reads must be facility staff/admin only.
      allow get: if resource != null && (
        // Legacy docs may not have submitted yet; treat as pre-submit
        !resource.data.keys().hasAny(['submitted']) ||
        resource.data.submitted != true ||
        isFacilityStaff() ||
        isAdmin()
      );
      // Only facility staff can list/query
      allow list: if isFacilityStaff();
      // Registration docs are created by Cloud Functions (Admin SDK), not clients
      allow create: if false;
      // Registration submissions are written by Cloud Functions only
      allow update: if false;
      // Facility staff/admin may remove abandoned registrations from queue workflows
      allow delete: if isFacilityStaff() || isAdmin();
    }

    match /auctions/{zipCode} {
      allow read: if true;
      // Writes require an active promotion listing; bid processing goes through Cloud Functions
      allow create, update: if isLoggedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/listings/$(zipCode)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/listings/$(zipCode)).data.status == 'active' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/listings/$(zipCode)).data.type == 'promotion';
      allow delete: if false;

      match /bids/{bidId} {
        allow read: if true;
        allow create: if isLoggedIn() &&
          request.resource.data.bidderId == request.auth.uid &&
          request.resource.data.keys().hasAll(['amount', 'bidderId', 'timestamp']);
        allow update, delete: if false;
      }
      match /archives/{archiveId} {
        allow read: if true;
        allow write: if request.auth.token.admin == true;
      }
    }

    match /statistics/{document} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /kijabe_users/{userId} {
      allow read: if isLoggedIn();
      allow write: if request.auth.token.admin == true;
    }

    match /backend_queries/{queryId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /assistants/{assistantId} {
      allow read, write: if isAdmin();
    }

    match /usage_monthly/{yearMonth} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /usage_records/{recordId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /hipaaTasks/{taskId} {
      // Compliance records are admin-only and immutable except status/evidence updates.
      allow read: if isGlobalPromptAdmin();
      allow create, delete: if false;
      allow update: if isGlobalPromptAdmin() && isValidComplianceTaskUpdate();
    }

    match /adherenceRecords/{recordId} {
      allow read: if isLoggedIn() && request.auth.uid == resource.data.userId;
      allow create, update: if isLoggedIn() &&
        request.auth.uid == request.resource.data.userId &&
        request.resource.data.keys().hasAll(['userId', 'medicationId', 'status', 'timestamp']) &&
        request.resource.data.status in ['taken', 'missed', 'skipped'];
      allow delete: if false; // Audit trail — no client-side deletion of health records
    }

    match /kijabe_chat/{docId} {
      allow read: if isLoggedIn() && resource.data.userId == request.auth.uid;
      // userId must match the authenticated user
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() &&
        request.resource.data.userId == resource.data.userId &&
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messages', 'timestamp']) ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['message', 'messages', 'timestamp']));
      allow delete: if false;
    }

    match /chartmind/{sessionId} {
      allow read, delete: if isLoggedIn() && request.auth.uid == resource.data.userId;
      allow create: if isLoggedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['id', 'userId', 'createdAt', 'updatedAt', 'data']);
      allow update: if isLoggedIn() &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == request.auth.uid;
    }

    match /organizations/{orgId} {
      allow read: if isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == orgId;
      allow create: if isLoggedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.subscriptionOwnerId == request.auth.uid &&
        request.resource.data.keys().hasAll(['id', 'name', 'createdAt', 'createdBy', 'seats', 'subscriptionOwnerId']);
      allow update: if isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == orgId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isOrganizationOwner == true &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']);
      allow delete: if false;

      match /chartmind_usage_daily/{dateId} {
        allow read: if isAdmin() || isOrgAdminFor(orgId);
        allow create, update, delete: if false;
      }
    }

    match /invitations/{invitationId} {
      allow get: if isLoggedIn() && (
        request.auth.token.email == resource.data.email ||
        isOrgAdminFor(resource.data.organizationId)
      );
      allow list: if isLoggedIn() && isOrgAdminFor(resource.data.organizationId);
      allow create: if false; // Cloud functions only
      allow update: if isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == resource.data.organizationId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'revokedAt', 'revokedBy']);
      allow delete: if isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == resource.data.organizationId;
    }

    // LLM prompt manager collections
    match /llmQueries/{queryId} {
      allow read: if isPromptManager();
      allow create, update: if isPromptManager();
      allow delete: if false;
    }

    match /llmQueryVersions/{versionId} {
      allow read: if isPromptManager();
      allow create: if isPromptManager();
      allow update, delete: if false;
    }

    // Global prompt layer (trade-secret system prompts).
    // Restricted to custom-claim admins only.
    match /llmGlobalPrompts/{promptId} {
      allow read, create, update: if isGlobalPromptAdmin();
      allow delete: if false;

      match /history/{historyId} {
        allow read: if isGlobalPromptAdmin();
        allow create: if isGlobalPromptAdmin();
        allow update, delete: if false;
      }
    }

    // Unified local prompt overrides (org + regional).
    match /llmLocalPrompts/{docId} {
      allow read: if isGlobalPromptAdmin() ||
        (isLoggedIn() && request.auth.token.stripeRole == 'admin') ||
        (isLoggedIn() && resource.data.scope == 'org' && isOrgAdminFor(resource.data.scopeId)) ||
        (isLoggedIn() && resource.data.scope == 'region' && isRegionalAdminFor(resource.data.scopeId));

      allow create, write: if isGlobalPromptAdmin() || (
        isLoggedIn() &&
        (
          request.auth.token.stripeRole == 'admin' ||
          isOrgAdminFor(request.resource.data.scopeId)
        )
      ) || (
        isLoggedIn() &&
        request.resource.data.scope == 'region' &&
        isRegionalAdminFor(request.resource.data.scopeId)
      );

      allow delete: if false;

      match /history/{historyId} {
        allow read: if isGlobalPromptAdmin() || isLoggedIn();
        allow create: if isLoggedIn();
        allow update, delete: if false;
      }
    }

    // Deprecated in favor of llmLocalPrompts.
    match /llmRegionalPrompts/{docId} {
      allow read, write: if false;
    }

    // UI-readable query config metadata.
    match /llmQueryConfig/{promptId} {
      allow read: if isLoggedIn();
      allow create, update: if isGlobalPromptAdmin();
      allow delete: if false;
    }

    // Deprecated in favor of organizations/{orgId}/prompts/{promptId}.
    match /llmOrganizationPrompts/{promptId} {
      allow read, write: if false;
    }

    // ================================================================
    // LEGACY / DISABLED COLLECTIONS
    // ================================================================

    // Top-level medication reference list — replaced by users/{uid}/medications subcollection
    match /medications/{medication} {
      allow read, write: if false;
    }

    // Disease reference list — only referenced in DiscussSymptomsPage (unrouted)
    match /diseases/{disease} {
      allow read, write: if false;
    }

    // Population geo-data — only referenced in KijabeContextBox (never imported)
    match /populations/{id} {
      allow read, write: if false;
    }

    // Nearby zip data — only referenced in KijabeContextBox (never imported)
    match /zips_near/{id} {
      allow read, write: if false;
    }

    // Public chatbot — feature disabled, route commented out in AppRoutes.jsx
    match /unauthenticated_chat/{threadId} {
      allow read, write: if false;
    }

  }

  // ================================================================
  // HELPER FUNCTIONS
  // ================================================================

  function isLoggedIn() {
    return request.auth != null;
  }

  function isAdmin() {
    // Custom claim only. Use scripts/setAdminClaim.js.
    return request.auth != null && request.auth.token.admin == true;
  }

  function isGlobalPromptAdmin() {
    return request.auth != null && request.auth.token.admin == true;
  }

  function isOrgAdminFor(orgId) {
    return request.auth != null &&
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == orgId &&
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
  }

  // users.region must equal llmLocalPrompts scopeId when scope == region (opaque string for now).
  function isRegionalAdminFor(regionScopeId) {
    return request.auth != null &&
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'regional_admin' &&
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region == regionScopeId;
  }

  function isFacilityStaff() {
    return request.auth != null &&
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['facility', 'professional'];
  }

  function isPromptManager() {
    return request.auth != null && (
      isAdmin() ||
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in [
        'admin',
        'llm-manager-global',
        'llm-manager-regional',
        'chartmind-admin',
        'chartmind-supervisor',
        'dscr-admin'
      ]
    );
  }

  function isValidComplianceTaskUpdate() {
    let allowed = ['status', 'completedAt', 'completedBy', 'driveLink', 'notes'];
    return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed) &&
      request.resource.data.status in ['pending', 'in-progress', 'done'] &&
      (
        request.resource.data.status == 'done' ||
        (request.resource.data.completedAt == null && request.resource.data.completedBy == null)
      ) &&
      (
        !request.resource.data.keys().hasAny(['driveLink']) ||
        request.resource.data.driveLink == null ||
        request.resource.data.driveLink is string
      ) &&
      (
        !request.resource.data.keys().hasAny(['notes']) ||
        request.resource.data.notes == null ||
        request.resource.data.notes is string
      );
  }

  function isValidUser() {
    return request.auth.uid in resource.data.users;
  }

}
